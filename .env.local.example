# =====================================================
# Configuração Supabase (OPCIONAL)
# =====================================================
# Sem essas variáveis, o sistema roda em modo localStorage
# (dados persistem no navegador mas não sincronizam entre devices)
#
# Como ativar Supabase real:
# 1. Crie conta gratuita em https://supabase.com
# 2. Crie um projeto novo (escolha região "São Paulo")
# 3. Settings → API → copie os valores abaixo
# 4. Renomeie este arquivo para .env.local
# 5. Cole as credenciais
# 6. Rode o SQL em supabase/schema.sql no SQL Editor do Supabase
# 7. Reinicie o servidor (pnpm dev)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
